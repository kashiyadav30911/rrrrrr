# AI API Configuration
# OpenRouter API
# Create a file named .env.local in the project root and set your real key there.
# Example:
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Optional fallback provider
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Base URL used to generate absolute links (OG images, metadata, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional deployment smoke prompt used by scripts/verify-deployment.mjs
# DEPLOY_SMOKE_PROMPT=Reply with exactly: OK
